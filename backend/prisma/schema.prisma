// Comflex Platform — Prisma Schema
// Database: MongoDB
// See RULES.md for data model documentation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER — Core user model with global ring and profile data
// ============================================================
model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  username       String?  @unique   // chosen during registration
  usernameChangedAt DateTime?       // last username change (30-day cooldown)
  password       String             // bcrypt hashed (empty string for Google-only until set)
  displayName    String
  avatarUrl      String?
  bio            String?  @default("")
  globalRing     Int      @default(3) // 0=Admin, 1=Manager, 2=Elevated, 3=Member, 4+=Restricted
  cohortTags     String[] // e.g. ["cohort-28", "cohort-28-27", "branch-cs"]
  cfHandle       String?
  cfRating       Int?
  creditBalance  Int      @default(0)
  subscriptionPlan   String?  @default("free") // "free", "pro", "ultra"
  subscriptionExpiry DateTime?
  backupSubscriptionPlan   String?
  backupSubscriptionExpiry DateTime?
  chatbotStorageUsed Int?     @default(0) // in bytes
  dailyUploadCount   Int?     @default(0)
  lastUploadDate     DateTime? @default(now())
  dailyChatTokens    Int?     @default(20) // limits free tier messages
  displayBadges  String[] // badge IDs currently displayed (max 5)

  // Google OAuth fields
  googleId              String?  //@unique  // Google OAuth sub ID
  hasPassword           Boolean  @default(true) // false for Google-only accounts until password set

  // Personal email verification
  personalEmail         String?            // secondary/personal email
  personalEmailVerified Boolean  @default(false)
  emailVerifyToken      String?
  emailVerifyExpiry     DateTime?

  // Admin-delegated permissions
  canCreateGroups       Boolean  @default(false)
  canCreateEvents       Boolean  @default(false)
  canManageResources    Boolean  @default(false)

  // Session & security tokens
  refreshToken     String?  // hashed refresh token
  resetToken       String?  // password reset token (hashed)
  resetTokenExpiry DateTime? // expiry for the reset token

  createdAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  groupMemberships GroupMember[]
  messages         Message[]

  // Event Relations
  eventsCreated     Event[]            @relation("EventCreator")
  eventRoles        EventOrganizer[]
  teamsLed          EventTeam[]        @relation("TeamLeader")
  eventMemberships  EventTeamMember[]
  eventTeamInvites  EventTeamInvite[]
  evaluatedSubmissions EventSubmission[]
  pointAdjustments   TeamPointAdjustment[]

  // Resources Relations
  resourcesUploaded Resource[]

  // Credits & Badges Relations
  acquiredBadges    UserBadge[]
  chatbotNotes      ChatbotNote[]
  canManageStore    Boolean   @default(false) // Whether user can manage store (create badges/listings)
  sentTransactions  Transaction[] @relation("Sender")
  receivedTransactions Transaction[] @relation("Receiver")
}

// ============================================================
// INSTITUTION CONFIG — Singleton storing platform-wide settings
// Configured by Seed Admin on first boot
// ============================================================
model InstitutionConfig {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String   @default("Unconfigured Institution")
  domain            String   @default("")
  logoUrl           String?
  isConfigured      Boolean  @default(false) // Gates user registration
  defaultCredits    Int      @default(1000)  // Credits given to new users on registration
  notesDownloadReward Int    @default(0)     // Credits awarded per resource download
  emailParsingRules Json?    // { pattern, captureGroup, branchCaptureGroup?, branchMapping?, yearOffset }
  membershipConfig  Json?    // { proWeekly: 0.005, proMonthly: 0.015, proYearly: 0.15, ultraWeekly: 0.01, ultraMonthly: 0.03, ultraYearly: 0.3 }
  cohortConfig      Json?    // { seniorOffset: -1, juniorOffset: +1, seniorAutoElevate: true }
  autoJoinRules     Json?    // [{ matchField: "year"|"branch"|"both", matchValue: "28", groupId: "..." }]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================================
// COHORT GROUP — A group (primary cohort, cross-year, or custom)
// Created automatically when users are tagged, or manually by admin
// ============================================================
model CohortGroup {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique // e.g. "cohort-28", "cohort-28-27", "study-group-ds"
  displayName String?          // e.g. "Class of 2028", "2028-2027 Cross-Year"
  description String?          // group description
  avatarUrl   String?          // group avatar image
  type        String           // "primary" | "cross-year" | "custom"
  creatorId   String?  @db.ObjectId // User who created the group (null for system-created)
  ringConfig  Json?            // { ringCount: 5, ringLabels: { 0: "Admin", 1: "Manager", ... } }
  inviteToken String?          // unique token for invite links
  createdAt   DateTime @default(now())

  // Relations
  members  GroupMember[]
  mutes    MuteRecord[]
  messages Message[]
  invites  GroupInvite[]
}

// ============================================================
// GROUP MEMBER — Per-group membership with ring and permissions
// A user's ring and permissions can vary per group
// ============================================================
model GroupMember {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  userId      String @db.ObjectId
  groupId     String @db.ObjectId
  ring        Int    @default(3) // Per-group ring level
  permissions Json?  // Granular permissions override (see RULES.md §6)

  joinedAt DateTime @default(now())

  // Relations
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  group CohortGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Unique constraint: one membership per user per group
  @@unique([userId, groupId])
}

// ============================================================
// GROUP INVITE — Join request for non-friend users
// ============================================================
model GroupInvite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId   String   @db.ObjectId
  userId    String   @db.ObjectId  // the invited user
  invitedBy String   @db.ObjectId  // who invited them
  status    String   @default("pending") // "pending" | "accepted" | "rejected"
  createdAt DateTime @default(now())

  // Relations
  group CohortGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

// ============================================================
// MESSAGE — Chat message in a group
// ============================================================
model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId     String   @db.ObjectId
  authorId    String   @db.ObjectId
  content     String
  attachments String[] @default([])
  mentions    String[] @default([])
  isPinned    Boolean  @default(false)
  pinnedAt    DateTime?
  isDeleted   Boolean  @default(false)
  
  // Chat Actions & Multimedia
  replyToId   String?  @db.ObjectId
  reactions   Json?    
  forwarded   Boolean  @default(false)
  msgType     String   @default("text") // text, image, document, sticker
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  mimetype    String?
  createdAt   DateTime @default(now())
  editedAt    DateTime?

  // Relations
  group        CohortGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author       User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  readReceipts MessageReadReceipt[]
}

// ============================================================
// MESSAGE READ RECEIPT — Tracks who has read which group message
// ============================================================
model MessageReadReceipt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  messageId String   @db.ObjectId
  userId    String   @db.ObjectId
  readAt    DateTime @default(now())

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

// ============================================================
// MUTE RECORD — Tracks muted users per group
// ============================================================
model MuteRecord {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  groupId   String   @db.ObjectId
  mutedBy   String   @db.ObjectId
  mutedUntil DateTime
  createdAt DateTime @default(now())

  // Relations
  group CohortGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

// ============================================================
// FRIENDSHIP — Friend requests and connections between users
// ============================================================
model Friendship {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  requesterId String  @db.ObjectId
  addresseeId String  @db.ObjectId
  status      String  @default("pending") // "pending" | "accepted" | "blocked"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
}

// ============================================================
// DIRECT MESSAGE — 1-on-1 messages between friends
// ============================================================
model DirectMessage {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String    @db.ObjectId
  receiverId String    @db.ObjectId
  content    String
  isRead     Boolean   @default(false)
  readAt     DateTime?            // When the message was read
  isDeleted  Boolean   @default(false)
  
  // Chat Actions & Multimedia
  replyToId   String?  @db.ObjectId
  reactions   Json?    
  forwarded   Boolean  @default(false)
  msgType     String   @default("text") // text, image, document, sticker
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  mimetype    String?

  createdAt  DateTime  @default(now())
  editedAt   DateTime?
}

// ============================================================
// EVENT MANAGEMENT
// ============================================================
model Event {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime?
  durationHours   Int      @default(0)
  durationMinutes Int      @default(0)
  status          String   @default("draft") // draft, published, ongoing, completed
  category        String   // app, web, cybersec, etc
  targetTags      String[] // e.g. ["cohort-28", "branch-cs", "cohort-28-cs"]
  creatorId       String   @db.ObjectId
  
  // Tasks configurations
  taskViewMode    String   @default("all") // "all" or "dynamic" (sequential)
  scoreMode       String   @default("constant") // "constant" or "dynamic"
  wrongSubmissionPenalty Int @default(0)

  // Subevent logic
  parentId        String?  @db.ObjectId
  keepTeamsSame   Boolean  @default(false)

  // Team configurations
  isTeamEvent     Boolean  @default(false)
  minTeamSize     Int      @default(1)
  maxTeamSize     Int      @default(1)

  // Timer configurations
  autoStart       Boolean  @default(true)

  rewardTiers     Json?    // [{ rank: 1, credits: 500, badgeId: "optional-id" }]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  creator         User             @relation("EventCreator", fields: [creatorId], references: [id])
  parentEvent     Event?           @relation("SubEvents", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subEvents       Event[]          @relation("SubEvents")
  organizers      EventOrganizer[]
  teams           EventTeam[]
  teamInvites     EventTeamInvite[]
  tasks           EventTask[]
  submissions     EventSubmission[]
  pointAdjustments TeamPointAdjustment[]
}

model EventOrganizer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String   @db.ObjectId
  userId      String   @db.ObjectId
  ring        Int      @default(2) // 0=Creator, 1=Co-organizer, 2=Volunteer
  permissions Json?    // { canEditDetails, canCreateSubevents, canManageTeams, canAwardPoints, canManageRoles, canGiveNextPhaseAccess }
  
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventTeam {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId          String   @db.ObjectId
  name             String
  leaderId         String   @db.ObjectId
  proposedLeaderId String?  @db.ObjectId
  status           String   @default("pending") // pending, registered, qualified_for_next_phase
  points           Int      @default(0)         // For leaderboard/awarding points
  
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leader      User     @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  members     EventTeamMember[]
  invites     EventTeamInvite[]
  submissions EventSubmission[]
  pointAdjustments TeamPointAdjustment[]

  @@unique([eventId, name])
}

model EventTeamMember {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId      String   @db.ObjectId
  userId      String   @db.ObjectId
  status      String   @default("unverified") // unverified, verified
  joinedAt    DateTime @default(now())
  
  team        EventTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model EventTeamInvite {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId         String   @db.ObjectId
  eventId        String   @db.ObjectId
  invitedUserId  String   @db.ObjectId
  invitedBy      String   @db.ObjectId
  status         String   @default("pending") // pending, accepted, rejected
  createdAt      DateTime @default(now())

  team           EventTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser    User      @relation(fields: [invitedUserId], references: [id], onDelete: Cascade)
  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([teamId, invitedUserId])
}

model EventTask {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId         String   @db.ObjectId
  title           String
  description     String
  order           Int      // For sequential viewing if dynamic
  basePoints      Int      @default(100)
  
  // Customization
  submissionType   String   @default("text") // text, file, url, mcq, true_false, checkboxes
  submissionConfig Json?    // { options: ["A", "B"], correctOptions: ["A"], exactText: "myflag" }
  isAutoEvaluated Boolean  @default(false)
  
  isDynamicScore  Boolean  @default(false)
  decayPercentage Float    @default(0) // Percentage of basePoints lost per elapsed minute
  wrongSubmissionPenalty Int @default(0) // Penalty deducted per wrong submit
  
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submissions     EventSubmission[]
}

model EventSubmission {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId         String   @db.ObjectId
  teamId          String   @db.ObjectId
  taskId          String   @db.ObjectId
  content         Json     // e.g. { text: "flag" }, { url: "github.com/..." }, { selectedOptions: ["A"] }
  status          String   @default("pending") // pending, correct, wrong
  scoreAwarded    Int      @default(0)
  submittedAt     DateTime @default(now())
  evaluatedAt     DateTime?
  evaluatedById   String?  @db.ObjectId // If manually graded

  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team            EventTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  task            EventTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  evaluator       User?     @relation(fields: [evaluatedById], references: [id])
}

// ============================================================
// POINT ADJUSTMENTS
// ============================================================
model TeamPointAdjustment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId      String   @db.ObjectId
  eventId     String   @db.ObjectId
  pointsAdded Int
  reason      String?
  awardedById String   @db.ObjectId
  createdAt   DateTime @default(now())

  team        EventTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  awardedBy   User      @relation(fields: [awardedById], references: [id])
}

// ============================================================
// RESOURCES
// ============================================================

model ResourceSubject {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  category    String   // "Academics" | "Technical"
  subCategory String?  // "Notes" | "Past_Year_Papers" (for Academics)
  yearGroup   String?  // "This Year" | "Last Year" (for Academics)
  createdAt   DateTime @default(now())
  
  resources   Resource[]

  @@unique([name, category, subCategory, yearGroup])
}

model Resource {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String?
  subjectId   String   @db.ObjectId
  fileUrl     String
  fileName    String
  fileSize    Int
  mimetype    String
  uploaderId  String   @db.ObjectId
  createdAt   DateTime @default(now())

  subject     ResourceSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  uploader    User            @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

// ============================================================
// CREDITS & BADGES SYSTEM (Web3 Ledger)
// ============================================================

model Badge {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   @unique
  description  String
  imageUrl     String
  isEventBadge Boolean  @default(false)
  createdAt    DateTime @default(now())

  storeListings StoreListing[]
  userBadges    UserBadge[]
}

model StoreListing {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  badgeId      String   @db.ObjectId
  price        Int
  quantity     Int      // -1 for infinite
  sold         Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  badge        Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
}

model UserBadge {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  badgeId    String   @db.ObjectId
  acquiredAt DateTime @default(now())
  source     String   // "store", "event", "admin"
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId]) // A user should only own one instance of a specific badge
}

model Transaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId    String?  @db.ObjectId // null if admin/system minting
  receiverId  String   @db.ObjectId
  amount      Int?
  type        String   // "transfer", "download_reward", "event_reward", "purchase", "admin_mint", "crypto_purchase"
  referenceId String?  // e.g. Resource ID, Event ID, Chat Message ID
  cryptoAmount String? // String to prevent precision loss for ETH
  tier         String?
  duration     String?
  createdAt   DateTime @default(now())

  sender      User?    @relation("Sender", fields: [senderId], references: [id])
  receiver    User     @relation("Receiver", fields: [receiverId], references: [id])
}

// ============================================================
// CHATBOT NOTES
// ============================================================
model ChatbotNote {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  title           String
  geminiFileUri   String
  geminiFileName  String
  fileSize        Int
  mimetype        String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

