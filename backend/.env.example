# ============================================================
# Comflex Backend — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Database (MongoDB connection string — requires a replica set)
DATABASE_URL="mongodb://localhost:27017/comflex?replicaSet=rs0"

# Server
PORT=5000
NODE_ENV=development

# JWT Secrets (CHANGE THESE IN PRODUCTION)
JWT_ACCESS_SECRET="your-access-secret-here-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-here-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Seed Admin (REQUIRED on first deploy)
SEED_ADMIN_EMAIL="admin@comflex.dev"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_DISPLAY_NAME="Platform Admin"

# CORS — Frontend origin
FRONTEND_URL="http://localhost:5173"

# Google OAuth (required for "Continue with Google" registration)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""

# Email Service
# Provider options: "console" (dev — logs to terminal) | "smtp"
EMAIL_PROVIDER="console"
EMAIL_FROM="noreply@comflex.dev"

# SMTP Config (only needed when EMAIL_PROVIDER=smtp)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Email API Key (for future providers like Resend/SendGrid)
EMAIL_API_KEY=""

# Gemini API Key (for Chatbot)
GEMINI_API_KEY=""

# EVM Treasury Address for Crypto Memberships (Placeholder for github)
TREASURY_ADDRESS="0x000..."
